  @@index([schoolId])
}

model InspectionTemplate {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  criteria  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school      School       @relation(fields: [schoolId], references: [id])
  inspections Inspection[]

  @@unique([schoolId, name])
}

model Inspection {
  id          String   @id @default(uuid())
  schoolId    String
  templateId  String?
  title       String
  inspector   String?
  status      String   @default("SCHEDULED")
  scheduledAt DateTime?
  completedAt DateTime?
  findings    Json?
  score       Decimal? @db.Decimal(6, 2)
  createdAt   DateTime @default(now())

  school            School             @relation(fields: [schoolId], references: [id])
  template          InspectionTemplate? @relation(fields: [templateId], references: [id])
  complianceActions ComplianceAction[]

  @@index([schoolId])
}

model ComplianceAction {
  id           String   @id @default(uuid())
  schoolId     String
  inspectionId String?
  title        String
  owner        String?
  status       String   @default("OPEN")
  dueAt        DateTime?
  closedAt     DateTime?
  createdAt    DateTime @default(now())

  school     School      @relation(fields: [schoolId], references: [id])
  inspection Inspection? @relation(fields: [inspectionId], references: [id])

  @@index([schoolId])
}

model GeoRegion {
  id        String   @id @default(uuid())
  schoolId  String
  parentId  String?
  name      String
  type      String
  code      String?
  metadata  Json?
  createdAt DateTime @default(now())

  school    School      @relation(fields: [schoolId], references: [id])
  parent    GeoRegion?  @relation("GeoRegionHierarchy", fields: [parentId], references: [id])
  children  GeoRegion[] @relation("GeoRegionHierarchy")
  locations Location[]

  @@index([schoolId])
  @@index([parentId])
}

model Location {
  id          String   @id @default(uuid())
  schoolId    String
  geoRegionId String?
  entityType  String
  entityId    String?
  name        String
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  address     String?
  metadata    Json?
  createdAt   DateTime @default(now())

  school    School     @relation(fields: [schoolId], references: [id])
  geoRegion GeoRegion? @relation(fields: [geoRegionId], references: [id])

  @@index([schoolId])
  @@index([geoRegionId])
  @@index([entityType, entityId])
}
