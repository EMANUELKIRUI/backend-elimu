generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  DISABLED
  INVITED
}

enum StudentStatus {
  APPLICANT
  ADMITTED
  ACTIVE
  TRANSFERRED
  GRADUATED
  ALUMNI
}

enum CurriculumType {
  KENYA_CBC
  KENYA_844
  GENERIC_MARKS
  GENERIC_COMPETENCY
}

enum AssessmentMode {
  MARKS
  COMPETENCY
}

enum ApprovalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  LOCKED
}

enum FinanceRequestStatus {
  DRAFT
  SUBMITTED
  DEPUTY_APPROVED
  PRINCIPAL_APPROVED
  REJECTED
  PAID
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ReportType {
  REPORT_CARD
  FEE_STATEMENT
  ATTENDANCE
  STUDENT_PROFILE
  ACADEMIC_SUMMARY
  FINANCE_SUMMARY
}

model SubscriptionPackage {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  monthlyFee  Decimal? @db.Decimal(12, 2)
  modules     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions SchoolSubscription[]
}

model School {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  country   String
  county    String?
  email     String?
  phone     String?
  logoUrl   String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions      SchoolSubscription[]
  settings           SchoolSetting[]
  users              User[]
  departments        Department[]
  academicYears      AcademicYear[]
  students           Student[]
  guardians          Guardian[]
  classes            Class[]
  streams            Stream[]
  subjects           Subject[]
  teacherClasses     TeacherClassAssignment[]
  teacherSubjects    TeacherSubjectAssignment[]
  exams              Exam[]
  examSubjects       ExamSubject[]
  examSchedules      ExamSchedule[]
  marks              Mark[]
  gradeScales        GradeScale[]
  approvals          AcademicApproval[]
  approvalComments   ApprovalComment[]
  studentAttendance  StudentAttendance[]
  staffAttendance    StaffAttendance[]
  feeStructures      FeeStructure[]
  invoices           Invoice[]
  invoiceItems       InvoiceItem[]
  payments           Payment[]
  paymentAllocations PaymentAllocation[]
  receipts           Receipt[]
  expenses           Expense[]
  reportSnapshots    ReportSnapshot[]
  auditLogs          AuditLog[]
}

model SchoolSetting {
  id        String   @id @default(uuid())
  schoolId  String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, key])
}

model SchoolSubscription {
  id        String             @id @default(uuid())
  schoolId  String
  packageId String
  status    SubscriptionStatus @default(TRIAL)
  startsAt  DateTime
  endsAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  school  School              @relation(fields: [schoolId], references: [id])
  package SubscriptionPackage @relation(fields: [packageId], references: [id])
}

model User {
  id           String     @id @default(uuid())
  schoolId     String?
  email        String?    @unique
  username     String?    @unique
  phone        String?    @unique
  passwordHash String
  firstName    String
  lastName     String
  status       UserStatus @default(ACTIVE)
  refreshHash  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  school             School?                    @relation(fields: [schoolId], references: [id])
  roles              UserRole[]
  departments        DepartmentMember[]
  classAssignments   TeacherClassAssignment[]   @relation("TeacherClassAssignments")
  subjectAssignments TeacherSubjectAssignment[] @relation("TeacherSubjectAssignments")
  marks              Mark[]                     @relation("MarkCreatedBy")
  createdApprovals   AcademicApproval[]         @relation("AcademicApprovalActor")
  approvalComments   ApprovalComment[]          @relation("ApprovalCommentAuthor")
  staffAttendance    StaffAttendance[]          @relation("StaffAttendanceUser")
  auditLogs          AuditLog[]
}

model Role {
  id          String   @id @default(uuid())
  schoolId    String?
  name        String
  description String?
  systemRole  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@unique([schoolId, name])
}

model Permission {
  id          String  @id @default(uuid())
  action      String  @unique
  description String?

  roles RolePermission[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model Department {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  code      String
  moduleKey String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School             @relation(fields: [schoolId], references: [id])
  members DepartmentMember[]

  @@unique([schoolId, code])
}

model DepartmentMember {
  id           String  @id @default(uuid())
  departmentId String
  userId       String
  isHod        Boolean @default(false)

  department Department @relation(fields: [departmentId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([departmentId, userId])
}

model AcademicYear {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  terms  Term[]
  exams  Exam[]

  @@unique([schoolId, name])
}

model Term {
  id             String   @id @default(uuid())
  academicYearId String
  name           String
  startsAt       DateTime
  endsAt         DateTime
  isActive       Boolean  @default(false)

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  exams        Exam[]

  @@unique([academicYearId, name])
}

model Curriculum {
  id          String            @id @default(uuid())
  type        CurriculumType
  name        String
  country     String?
  description String?
  levels      CurriculumLevel[]
  subjects    Subject[]
}

model CurriculumLevel {
  id           String @id @default(uuid())
  curriculumId String
  name         String
  sequence     Int

  curriculum Curriculum @relation(fields: [curriculumId], references: [id])
}

model Class {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  level     String
  createdAt DateTime @default(now())

  school             School                   @relation(fields: [schoolId], references: [id])
  streams            Stream[]
  students           Student[]
  teacherAssignments TeacherClassAssignment[]

  @@unique([schoolId, name])
}

model Stream {
  id       String @id @default(uuid())
  schoolId String
  classId  String
  name     String

  school   School    @relation(fields: [schoolId], references: [id])
  class    Class     @relation(fields: [classId], references: [id])
  students Student[]

  @@unique([classId, name])
}

model Subject {
  id           String         @id @default(uuid())
  schoolId     String
  curriculumId String?
  name         String
  code         String
  mode         AssessmentMode
  maxMarks     Int?
  createdAt    DateTime       @default(now())

  school             School                     @relation(fields: [schoolId], references: [id])
  curriculum         Curriculum?                @relation(fields: [curriculumId], references: [id])
  teacherAssignments TeacherSubjectAssignment[]
  examSubjects       ExamSubject[]
  examSchedules      ExamSchedule[]
  marks              Mark[]

  @@unique([schoolId, code])
}

model TeacherClassAssignment {
  id        String    @id @default(uuid())
  schoolId  String
  teacherId String
  classId   String
  startsAt  DateTime  @default(now())
  endsAt    DateTime?

  school  School @relation(fields: [schoolId], references: [id])
  teacher User   @relation("TeacherClassAssignments", fields: [teacherId], references: [id])
  class   Class  @relation(fields: [classId], references: [id])

  @@unique([teacherId, classId])
}

model TeacherSubjectAssignment {
  id        String    @id @default(uuid())
  schoolId  String
  teacherId String
  subjectId String
  classId   String?
  startsAt  DateTime  @default(now())
  endsAt    DateTime?

  school  School  @relation(fields: [schoolId], references: [id])
  teacher User    @relation("TeacherSubjectAssignments", fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId, classId])
}

model Student {
  id              String        @id @default(uuid())
  schoolId        String
  classId         String?
  streamId        String?
  admissionNumber String
  firstName       String
  lastName        String
  gender          String?
  dateOfBirth     DateTime?
  status          StudentStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  school         School                 @relation(fields: [schoolId], references: [id])
  class          Class?                 @relation(fields: [classId], references: [id])
  stream         Stream?                @relation(fields: [streamId], references: [id])
  guardians      StudentGuardian[]
  documents      StudentDocument[]
  medicalRecords StudentMedicalRecord[]
  transfers      StudentTransfer[]
  attendance     StudentAttendance[]
  marks          Mark[]
  invoices       Invoice[]
  payments       Payment[]

  @@unique([schoolId, admissionNumber])
}

model Guardian {
  id        String   @id @default(uuid())
  schoolId  String
  firstName String
  lastName  String
  phone     String
  email     String?
  createdAt DateTime @default(now())

  school   School            @relation(fields: [schoolId], references: [id])
  students StudentGuardian[]
}

model StudentGuardian {
  id         String  @id @default(uuid())
  studentId  String
  guardianId String
  relation   String
  primary    Boolean @default(false)

  student  Student  @relation(fields: [studentId], references: [id])
  guardian Guardian @relation(fields: [guardianId], references: [id])

  @@unique([studentId, guardianId])
}

model StudentDocument {
  id        String   @id @default(uuid())
  schoolId  String
  studentId String
  title     String
  fileUrl   String
  type      String?
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model StudentMedicalRecord {
  id         String   @id @default(uuid())
  schoolId   String
  studentId  String
  condition  String
  notes      String?
  recordedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model StudentTransfer {
  id            String   @id @default(uuid())
  schoolId      String
  studentId     String
  fromSchool    String?
  toSchool      String?
  reason        String?
  transferredAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model Exam {
  id             String         @id @default(uuid())
  schoolId       String
  academicYearId String
  termId         String
  name           String
  status         ApprovalStatus @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  school       School             @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear       @relation(fields: [academicYearId], references: [id])
  term         Term               @relation(fields: [termId], references: [id])
  subjects     ExamSubject[]
  schedules    ExamSchedule[]
  marks        Mark[]
  approvals    AcademicApproval[]

  @@unique([schoolId, academicYearId, termId, name])
}

model ExamSubject {
  id        String  @id @default(uuid())
  schoolId  String
  examId    String
  subjectId String
  weight    Decimal @default(1) @db.Decimal(6, 2)
  maxMarks  Int?

  school  School  @relation(fields: [schoolId], references: [id])
  exam    Exam    @relation(fields: [examId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([examId, subjectId])
}

model ExamSchedule {
  id        String   @id @default(uuid())
  schoolId  String
  examId    String
  subjectId String
  startsAt  DateTime
  endsAt    DateTime
  room      String?

  school  School  @relation(fields: [schoolId], references: [id])
  exam    Exam    @relation(fields: [examId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
}

model Mark {
  id          String         @id @default(uuid())
  schoolId    String
  examId      String
  studentId   String
  subjectId   String
  score       Decimal        @db.Decimal(6, 2)
  grade       String?
  points      Decimal?       @db.Decimal(6, 2)
  status      ApprovalStatus @default(DRAFT)
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  school    School  @relation(fields: [schoolId], references: [id])
  exam      Exam    @relation(fields: [examId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])
  createdBy User    @relation("MarkCreatedBy", fields: [createdById], references: [id])

  @@unique([examId, studentId, subjectId])
}

model GradeScale {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  school School       @relation(fields: [schoolId], references: [id])
  ranges GradeRange[]

  @@unique([schoolId, name])
}

model GradeRange {
  id           String   @id @default(uuid())
  gradeScaleId String
  minScore     Decimal  @db.Decimal(6, 2)
  maxScore     Decimal  @db.Decimal(6, 2)
  grade        String
  remark       String?
  points       Decimal? @db.Decimal(6, 2)

  gradeScale GradeScale @relation(fields: [gradeScaleId], references: [id])
}

model AcademicApproval {
  id        String         @id @default(uuid())
  schoolId  String
  examId    String
  actorId   String
  level     String
  status    ApprovalStatus
  createdAt DateTime       @default(now())

  school   School            @relation(fields: [schoolId], references: [id])
  exam     Exam              @relation(fields: [examId], references: [id])
  actor    User              @relation("AcademicApprovalActor", fields: [actorId], references: [id])
  comments ApprovalComment[]
}

model ApprovalComment {
  id         String   @id @default(uuid())
  schoolId   String
  approvalId String
  authorId   String
  comment    String
  createdAt  DateTime @default(now())

  school   School           @relation(fields: [schoolId], references: [id])
  approval AcademicApproval @relation(fields: [approvalId], references: [id])
  author   User             @relation("ApprovalCommentAuthor", fields: [authorId], references: [id])
}

model StudentAttendance {
  id        String           @id @default(uuid())
  schoolId  String
  studentId String
  date      DateTime
  status    AttendanceStatus
  notes     String?
  createdAt DateTime         @default(now())

  school  School  @relation(fields: [schoolId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
}

model StaffAttendance {
  id        String           @id @default(uuid())
  schoolId  String
  userId    String
  date      DateTime
  status    AttendanceStatus
  notes     String?
  createdAt DateTime         @default(now())

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation("StaffAttendanceUser", fields: [userId], references: [id])

  @@unique([userId, date])
}

model FeeStructure {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  classId   String?
  termId    String?
  createdAt DateTime @default(now())

  school School    @relation(fields: [schoolId], references: [id])
  items  FeeItem[]

  @@unique([schoolId, name])
}

model FeeItem {
  id             String  @id @default(uuid())
  feeStructureId String
  name           String
  amount         Decimal @db.Decimal(12, 2)

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
}

model Invoice {
  id        String    @id @default(uuid())
  schoolId  String
  studentId String
  number    String
  amount    Decimal   @db.Decimal(12, 2)
  balance   Decimal   @db.Decimal(12, 2)
  dueDate   DateTime?
  createdAt DateTime  @default(now())

  school      School              @relation(fields: [schoolId], references: [id])
  student     Student             @relation(fields: [studentId], references: [id])
  items       InvoiceItem[]
  payments    Payment[]
  allocations PaymentAllocation[]
  receipts    Receipt[]

  @@unique([schoolId, number])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  schoolId    String
  invoiceId   String
  description String
  amount      Decimal @db.Decimal(12, 2)

  school  School  @relation(fields: [schoolId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Payment {
  id         String   @id @default(uuid())
  schoolId   String
  studentId  String
  invoiceId  String?
  amount     Decimal  @db.Decimal(12, 2)
  method     String
  reference  String?
  receivedAt DateTime @default(now())

  school      School              @relation(fields: [schoolId], references: [id])
  student     Student             @relation(fields: [studentId], references: [id])
  invoice     Invoice?            @relation(fields: [invoiceId], references: [id])
  allocations PaymentAllocation[]
  receipt     Receipt?
}

model PaymentAllocation {
  id        String  @id @default(uuid())
  schoolId  String
  paymentId String
  invoiceId String
  amount    Decimal @db.Decimal(12, 2)

  school  School  @relation(fields: [schoolId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Receipt {
  id        String   @id @default(uuid())
  schoolId  String
  paymentId String   @unique
  invoiceId String?
  number    String
  issuedAt  DateTime @default(now())

  school  School   @relation(fields: [schoolId], references: [id])
  payment Payment  @relation(fields: [paymentId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@unique([schoolId, number])
}

model Expense {
  id          String               @id @default(uuid())
  schoolId    String
  title       String
  amount      Decimal              @db.Decimal(12, 2)
  status      FinanceRequestStatus @default(DRAFT)
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  school School @relation(fields: [schoolId], references: [id])
}

model ReportSnapshot {
  id        String     @id @default(uuid())
  schoolId  String
  type      ReportType
  title     String
  payload   Json
  createdAt DateTime   @default(now())

  school School @relation(fields: [schoolId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  schoolId  String?
  userId    String?
  action    String
  module    String
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  school School? @relation(fields: [schoolId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])
}
